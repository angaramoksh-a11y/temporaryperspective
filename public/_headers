# Cloudflare Workers static-assets headers (copied to out/ by `output: export`).
# Security hardening + long-term caching for content-hashed bundles.
# NOTE: HSTS + HTTP→HTTPS upgrade are set at the Cloudflare edge
# (SSL/TLS → Edge Certificates), not here.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# Content-hashed build assets never change under a given URL — cache hard.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
